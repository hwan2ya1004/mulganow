# KAMIS Open API 인증정보
# 발급: https://www.kamis.or.kr/customer/reference/openapi_write.do
# 아래 값을 실제 발급받은 키로 교체한 뒤, 파일명을 .env 로 변경하세요.

KAMIS_CERT_KEY=21350170-7655-438f-81e4-6bdc2a321d2c
KAMIS_CERT_ID=여기에_KAMIS_계정아이디_입력

# 애드픽(Adpick) API 키 (최저가 상품 검색 + 커미션 링크 기능)
# 발급: https://biz.adpick.co.kr → API KEY 관리 페이지
# 설정하면 소매가 모달에서 여러 제휴몰의 최저가 상품을 검색하고
# 커미션 링크가 자동으로 포함된 결과를 반환합니다.
ADPICK_API_KEY=여기에_애드픽_API_키_입력
