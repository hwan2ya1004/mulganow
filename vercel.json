{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "mulganow/frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/consumer",
      "dest": "mulganow/frontend/consumer.html"
    },
    {
      "src": "/consumer/",
      "dest": "mulganow/frontend/consumer.html"
    },
    {
      "src": "/(.*)",
      "dest": "mulganow/frontend/$1"
    }
  ]
}
